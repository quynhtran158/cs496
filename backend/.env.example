# ── MongoDB ────────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers → copy the connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cs496?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set this to your Render frontend URL once deployed (no trailing slash)
FRONTEND_URL=https://your-frontend-name.onrender.com

# ── Server ─────────────────────────────────────────────────────────────────────
# Render injects PORT automatically — do NOT set this in Render's dashboard
PORT=5001
